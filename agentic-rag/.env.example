# LLM Configuration
GOOGLE_API_KEY=your-google-api-key-here
MODEL_NAME=gemini-2.5-flash

# Vector Store Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=hr_policies
QDRANT_API_KEY=

# Embedding Model Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_KEY=your_api_key_here

# Email Configuration (for tools)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=hr@company.com
SMTP_PASSWORD=your_email_password_here
SMTP_FROM_EMAIL=hr@company.com

# Redis Configuration (optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Monitoring (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Feature Flags
ENABLE_CONVERSATIONAL_RAG=true
ENABLE_AGENTIC_RAG=true
ENABLE_CACHING=false
ENABLE_MONITORING=false

# Environment
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/hr_assistant.log

# Default Employee Database (mock)
DEFAULT_LEAVE_BALANCE_CASUAL=15
DEFAULT_LEAVE_BALANCE_SICK=10
DEFAULT_LEAVE_BALANCE_EARNED=12
