# Provisioning Agent Environment Configuration

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# n8n Webhook Configuration
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook
N8N_API_KEY=

# API Configuration
API_HOST=0.0.0.0
API_PORT=8003
API_WORKERS=1

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/provisioning.log

# Environment
ENVIRONMENT=development

# Retry Configuration
MAX_RETRIES=1
RETRY_DELAY_SECONDS=2

# Idempotency
ENABLE_IDEMPOTENCY_CHECK=true

# Security
WEBHOOK_TIMEOUT_SECONDS=30
