# Gemini AI Configuration
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash-exp

# Redis Configuration (Agent Communication Layer)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MongoDB Configuration (Workflow State Storage)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=agentichr

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=2

# Service URLs (Other Agents)
GUIDE_AGENT_URL=http://localhost:8000
LIAISON_AGENT_URL=http://localhost:8002
PROVISIONING_AGENT_URL=http://localhost:8003
SCHEDULER_AGENT_URL=http://localhost:8004

# n8n Webhook URLs
N8N_BASE_URL=http://localhost:5678
N8N_APPROVAL_WEBHOOK=/webhook/approval
N8N_NOTIFICATION_WEBHOOK=/webhook/notification

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/orchestrator.log

# Environment
ENVIRONMENT=development

# Task Retry Configuration
MAX_TASK_RETRIES=2
TASK_TIMEOUT_SECONDS=300
