# Scheduler Agent – Environment Configuration
# Copy this file to .env and fill in real values before starting the agent.

# -------------------------------------------------------------------
# Redis
# -------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password      # uncomment if auth enabled
REDIS_DB=0

# -------------------------------------------------------------------
# n8n Webhook
# -------------------------------------------------------------------
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook
# N8N_API_KEY=your_n8n_api_key            # uncomment if n8n auth enabled

# -------------------------------------------------------------------
# API server
# -------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8004
API_WORKERS=1

# -------------------------------------------------------------------
# Logging
# -------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/scheduler.log

# -------------------------------------------------------------------
# Environment
# -------------------------------------------------------------------
ENVIRONMENT=development

# -------------------------------------------------------------------
# Behaviour
# -------------------------------------------------------------------
MAX_RETRIES=1
RETRY_DELAY_SECONDS=2
ENABLE_IDEMPOTENCY_CHECK=true
WEBHOOK_TIMEOUT_SECONDS=30
